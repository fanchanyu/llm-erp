# 選擇 LLM Provider：anthropic, openai, deepseek, openrouter, ollama
LLM_PROVIDER=anthropic
LLM_MODEL=

# 只填你用的那家就好，其他留空
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=

# Ollama (本地 LLM)
# OLLAMA_BASE_URL=http://localhost:11434

# Database
DATABASE_URL=postgresql+asyncpg://erp_user:erp_pass_dev@localhost:5432/llm_erp

# Server
DEBUG=true
HOST=0.0.0.0
PORT=8000
