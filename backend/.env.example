# 選擇 LLM Provider：anthropic, openai, deepseek, openrouter, ollama
LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-chat

# LLM 設定
MAX_TOOL_ROUNDS=5        # 每請求最大工具調用輪數 (cloud=5, local=8-10)

# 只填你用的那家就好，其他留空
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=sk-your-key-here
OPENROUTER_API_KEY=

# Ollama (本地 LLM)
# OLLAMA_BASE_URL=http://localhost:11434

# Database (dev: SQLite; prod: uncomment PostgreSQL)
DATABASE_URL=sqlite+aiosqlite:///./llm_erp.db
# DATABASE_URL=postgresql+asyncpg://erp_user:erp_pass_dev@localhost:5432/llm_erp

# Server
DEBUG=true
HOST=0.0.0.0
PORT=8000
